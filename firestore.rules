rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function existing() {
      return resource.data;
    }

    function incoming() {
      return request.resource.data;
    }

    function getCurrentUserRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) ? 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role : 'none';
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'nahid.mfal.mis@gmail.com' ||
        getCurrentUserRole() == 'superadmin'
      );
    }

    function isSubAdmin() {
      return isSignedIn() && getCurrentUserRole() == 'subadmin';
    }

    function isAdmin() {
      return isSuperAdmin() || isSubAdmin();
    }

    function hasPermission(module) {
      return isSuperAdmin() || (isSubAdmin() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions[module] == true);
    }

    // --- USERS ---
    function isValidUser(data) {
      return data.keys().hasAll(['userId', 'email', 'role', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.email is string &&
             data.role in ['customer', 'superadmin', 'subadmin'] &&
             data.createdAt is number;
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming()) && (incoming().role == 'customer' || (incoming().role == 'superadmin' && incoming().email == 'nahid.mfal.mis@gmail.com'));
      allow update: if isSignedIn() && (
        (request.auth.uid == userId && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'shippingAddress', 'referralCode']) && incoming().role == existing().role) ||
        isSuperAdmin()
      );
      allow delete: if isSuperAdmin();
    }

    // --- PRODUCTS ---
    match /products/{productId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // --- ORDERS ---
    match /orders/{orderId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidOrder(incoming()) && incoming().status == 'pending';
      allow update: if isSignedIn() && (
        hasPermission('orders') ||
        (existing().userId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['status']) && existing().status == 'pending' && incoming().status == 'cancelled')
      );
    }

    // --- VOUCHERS ---
    match /vouchers/{voucherId} {
      allow read: if true;
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin() || (incoming().diff(existing()).affectedKeys().hasOnly(['isUsed']) && existing().isUsed == false && incoming().isUsed == true);
      allow delete: if isSuperAdmin();
    }

    // --- PAGES ---
    match /pages/{pageId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // --- SETTINGS ---
    match /settings/{docId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // --- CATEGORIES ---
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // --- APPROVALS ---
    match /approvals/{approvalId} {
      allow read: if isAdmin();
      allow create: if isSubAdmin();
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }
  }
}
